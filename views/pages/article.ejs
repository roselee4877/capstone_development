<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= article.title %> - News</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
    <script>
        const colors = tailwind.colors;
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6366F1",
                        "background-light": "#F9FAFB",
                        "background-dark": "#1F2937",
                        "card-light": "#FFFFFF",
                        "card-dark": "#374151",
                        "text-light": "#111827",
                        "text-dark": "#F3F4F6",
                        "text-secondary-light": "#6B7280",
                        "text-secondary-dark": "#9CA3AF",
                        "border-light": "#E5E7EB",
                        "border-dark": "#4B5563",

                        "pol-left": colors.blue[400],
                        "pol-lean-left": colors.blue[200],
                        "pol-center": colors.gray[300],
                        "pol-lean-right": colors.red[200],
                        "pol-right": colors.red[400],

                        "pol-highlight-left": colors.blue[300],
                        "pol-highlight-lean-left": colors.blue[200],
                        "pol-highlight-center": colors.gray[200],
                        "pol-highlight-lean-right": colors.red[200],
                        "pol-highlight-right": colors.red[300],
                    },
                    fontFamily: { display: ["Noto Sans KR", "sans-serif"] },
                },
            },
        };
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark font-display">
    <div class="container mx-auto px-4 md:px-12 lg:px-20 py-8 max-w-7xl">
        <% 
        // URL에 isSplit=true가 있는지 확인합니다.
        const isSplitView = (typeof isSplit !== 'undefined' && isSplit === 'true');
        %>

        <% if (!isSplitView) { %>
        <header class="flex items-center space-x-4 mb-8">
            <div class="flex items-center space-x-4 flex-grow">
                <a href="/" class="flex items-center gap-2 bg-primary text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-indigo-600 transition-colors">
                    <span class="material-icons">home</span>
                </a>
                <div class="relative flex-grow">
                    <input id="searchInput" 
                        class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-card-light dark:bg-card-dark focus:outline-none focus:ring-2 focus:ring-primary" 
                        placeholder="Search by keyword" 
                        type="text"
                        onkeyup="if(window.event.keyCode==13){executeSearch()}"/>
                        
                    <button onclick="executeSearch()" 
                            class="absolute right-0 top-0 h-full px-3 flex items-center bg-primary text-white rounded-r-lg hover:bg-indigo-700 transition-colors duration-300">
                        <span class="material-icons">search</span>
                    </button>
                </div>
            </div>
            <a href="/logout" class="ml-4 bg-gray-200 dark:bg-gray-700 text-text-light dark:text-text-dark px-6 py-2 rounded-lg font-semibold shadow-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-300">
                    log out
            </a>
        </header>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <main id="view-container" class="lg:col-span-2 flex gap-4 transition-all duration-500">
                <article id="left-view" class="w-full bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md transition-all duration-500">
                    <div class="prose dark:prose-invert max-w-none">
                        <h1 class="text-3xl font-bold mb-8"><%= article.title %></h1>
                        
                        <div class="text-lg leading-relaxed space-y-4">
                        <% 
                            const currentKeywords = (typeof keywords !== 'undefined' && keywords) ? keywords : [];
                            let highlightedContent = article.article_content || '';

                            let colorClass = "";
                            const label = article.label; 
                            if (label === 'Left') colorClass = "pol-highlight-left";
                            else if (label === 'Right') colorClass = "pol-highlight-right";
                            else if (label === 'Lean Left') colorClass = "pol-highlight-lean-left";
                            else if (label === 'Lean Right') colorClass = "pol-highlight-lean-right";
                            else colorClass = "pol-highlight-center";

                            if (highlightedContent && currentKeywords.length > 0) {
                                //group keywords by their associated sentences
                                const sentenceMap = new Map();
                                currentKeywords.forEach(item => {
                                    const s = (item.sentence || "").trim();
                                    if (!s) return;
                                    if (!sentenceMap.has(s)) sentenceMap.set(s, []);
                                    sentenceMap.get(s).push((item.keyword || "").trim());
                                });

                                // 2. 문장 길이가 긴 순서대로 처리 (중복 방지) 
                                const sortedSentences = Array.from(sentenceMap.keys()).sort((a, b) => b.length - a.length);

                                sortedSentences.forEach(fullSentence => {
                                    const keywords = sentenceMap.get(fullSentence);
                                    
                                    const flexibleSentence = fullSentence
                                        .replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
                                        .replace(/[^a-zA-Z0-9\s]/g, '.?')
                                        .replace(/\s+/g, '([\\s\\n\\r]|<br\\s*\\/?>)+');

                                    try {
                                        const sentenceRegex = new RegExp(flexibleSentence, 'gi');

                                        highlightedContent = highlightedContent.replace(sentenceRegex, (match) => {
                                            let updatedMatch = match;
                                            
                                            // 해당 문장 안에 포함된 모든 키워드에 대해 순차적으로 replace 수행
                                            keywords.forEach(word => {
                                                // 키워드를 공백 기준으로 단어들로 분리
                                                const tokens = word.split(/\s+/).filter(t => t.length > 0);
                                                
                                                let wordRegex;
                                                if (tokens.length <= 1) {
                                                    // 단일 단어: 기존 방식 그대로
                                                    const escapedWord = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                                                    wordRegex = new RegExp(`(${escapedWord})`, 'gi');
                                                } else {
                                                    // 여러 단어: 단어 사이에 다른 단어가 끼어들 수 있도록 처리
                                                    // 각 토큰을 이스케이프하고, 사이에 "최대 30자 이내의 임의 문자" 허용
                                                    // (HTML 태그가 끼면 안 되므로 < > 는 제외)
                                                    const escapedTokens = tokens.map(t => 
                                                        t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
                                                    );
                                                    // 단어 경계(\b)로 감싸고, 사이에는 < > 가 없는 임의 문자 0~30자 허용
                                                    const pattern = escapedTokens
                                                        .map(t => `(${t})`)
                                                        .join('([^<>]{0,30}?)');
                                                    wordRegex = new RegExp(pattern, 'gi');
                                                }
                                                const safeWord = word.replace(/'/g, "&apos;").replace(/"/g, "&quot;");

                                                updatedMatch = updatedMatch.replace(wordRegex, (...args) => {
                                                    // args: [전체매칭, 캡처1, 캡처2, ..., offset, fullString]
                                                    // 다중 단어인 경우: 캡처 그룹들이 [단어1, 갭1, 단어2, 갭2, 단어3, ...] 형태로 들어옴
                                                    // 단일 단어인 경우: 캡처 그룹이 [단어] 하나만 있음
                                                    const fullMatch = args[0];
                                                    
                                                    // 이미 하이라이트된 영역이라면 건너뛰기
                                                    if (fullMatch.includes('keyword-highlight')) return fullMatch;
                                                    
                                                    const currentSafeWord = word.replace(/'/g, "&apos;").replace(/"/g, "&quot;");
                                                    
                                                    let descriptionColorClass = "";
                                                    if (label == 'Left') {
                                                        descriptionColorClass = "bg-blue-100 dark:bg-blue-950/20 border-blue-100 dark:border-blue-900";
                                                    } else if (label == "Lean Left") {
                                                        descriptionColorClass = "bg-blue-100 dark:bg-blue-950/20 border-blue-100 dark:border-blue-900";
                                                    } else if (label == "Lean Right") {
                                                        descriptionColorClass = "bg-red-100 dark:bg-red-950/20 border-red-100 dark:border-red-900";
                                                    } else if (label == 'Right') {
                                                        descriptionColorClass = "bg-red-100 dark:bg-red-950/20 border-red-100 dark:border-red-900";
                                                    } else {
                                                        descriptionColorClass = "bg-gray-100 dark:bg-gray-800/40 border-gray-100 dark:border-gray-700";
                                                    }
                                                    
                                                    // 공통 expander/highlight HTML을 생성하는 헬퍼
                                                    const buildHighlight = (displayText) => {
                                                        const uniqueId = `expander-${Math.random().toString(36).substr(2, 9)}`;
                                                        return `
                                                        <span class="${colorClass} border-b-2 font-medium cursor-pointer keyword-highlight hover:text-primary transition-colors inline" 
                                                            onclick="toggleExpander('${uniqueId}', '${currentSafeWord}')">
                                                            ${displayText}
                                                        </span>
                                                        <div id="${uniqueId}" class="expander-content hidden w-full overflow-hidden transition-all duration-300 ease-in-out">
                                                            <div class="mb-1 pt-2 pb-2 px-5 rounded-xl shadow-sm border ${descriptionColorClass}">
                                                                <div class="flex justify-between items-center mb-1">
                                                                    <h4 class="text-base font-bold text-text-light dark:text-text-dark leading-none">
                                                                        ${displayText}
                                                                    </h4>
                                                                    <button onclick="event.stopPropagation(); closeExpander('${uniqueId}')" class="text-gray-400 hover:text-gray-600 p-1">
                                                                        <span class="material-icons text-sm text-gray-400 hover:text-gray-600 cursor-pointer">close</span>
                                                                    </button>
                                                                </div>
                                                                <p class="text-sm leading-relaxed text-text-light dark:text-text-dark font-normal description-text opacity-90">
                                                                    <span class="flex items-center gap-2 italic">
                                                                        <span class="animate-pulse w-2 h-2 bg-primary rounded-full"></span>
                                                                        Analyzing context...
                                                                    </span>
                                                                </p>
                                                            </div>
                                                        </div>`;
                                                    };
                                                    
                                                    if (tokens.length <= 1) {
                                                        // 단일 단어: 매칭된 텍스트를 통째로 하이라이트
                                                        return buildHighlight(fullMatch);
                                                    } else {
                                                        // 다중 단어: 캡처 그룹을 순회하며 홀수번째(단어)는 하이라이트, 짝수번째(갭)는 그대로
                                                        // 캡처 그룹 개수: tokens.length개의 단어 + (tokens.length - 1)개의 갭
                                                        const captureCount = tokens.length * 2 - 1;
                                                        let result = '';
                                                        for (let i = 0; i < captureCount; i++) {
                                                            const captured = args[i + 1] || '';
                                                            if (i % 2 === 0) {
                                                                // 단어 부분 → 하이라이트
                                                                result += buildHighlight(captured);
                                                            } else {
                                                                // 갭 부분 → 그대로 두기
                                                                result += captured;
                                                            }
                                                        }
                                                        return result;
                                                    }
                                                });
                                                
                                            });
                                            return updatedMatch;
                                        });
                                    } catch (e) {
                                        console.error("error:", fullSentence);
                                    }
                                });
                            }
                        %>


                            <div class="text-lg leading-relaxed space-y-4 article-body">
                                <%- highlightedContent %>
                            </div>
                        </div>

                        
                    </div>
                </article>

                <div id="right-view" class="hidden w-0 bg-card-light dark:bg-card-dark rounded-lg shadow-md border-l border-border-light dark:border-border-dark flex flex-col transition-all duration-500 overflow-hidden">
                    <div class="flex justify-between items-center p-4 border-b border-border-light dark:border-border-dark">
                        <button id="full-view-btn" class="text-primary hover:underline text-sm font-bold">View Full Page</button>
                        <button onclick="closeSplitView()" class="p-1 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-full">
                            <span class="material-icons">close</span>
                        </button>
                    </div>
                    <iframe id="right-iframe" class="w-full h-full border-none"></iframe>
                </div>

                
            </main>

            <div id="keywordModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden items-center justify-center z-50 p-4 transition-all duration-300" onclick="if(event.target === this) closeModal()">
                <div class="bg-card-light dark:bg-card-dark max-w-2xl w-full rounded-2xl shadow-2xl flex flex-col max-h-[75vh] overflow-hidden transform transition-all shadow-indigo-500/10">
                    
                    <div class="px-6 py-4 border-b border-border-light dark:border-border-dark flex items-center justify-between bg-gray-50/50 dark:bg-gray-800/50">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                                <span class="material-icons text-primary">auto_awesome</span>
                            </div>
                            <div>
                                <h3 id="modalTitle" class="text-xl font-bold text-text-light dark:text-text-dark tracking-tight"></h3>
                                <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark font-medium  tracking-wider">Why is this keyword highlighted?</p>
                            </div>
                        </div>
                        <button onclick="closeModal()" class="p-2 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-all group">
                            <span class="material-icons text-text-secondary-light group-hover:rotate-90 transition-transform duration-300">close</span>
                        </button>
                    </div>

                    <div id="modalContent" class="p-8 overflow-y-auto text-text-light dark:text-text-dark leading-relaxed text-lg whitespace-pre-wrap scrollbar-thin scrollbar-thumb-gray-300 dark:scrollbar-thumb-gray-600">
                        </div>
                </div>
            </div>

            <% if (!isSplitView) { %>
            <aside class="space-y-8">
                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <h3 class="text-lg font-semibold mb-4">Predicted Political Bias</h3>
                    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-xl h-14 overflow-hidden flex text-white text-xs font-bold shadow-inner">
                        
                        <div class="flex flex-col items-center justify-center bg-pol-left border-r border-white/20 transition-all duration-500" 
                            style="width: <%= stats.Left %>%">
                            <% if (stats.Left > 5) { %> 
                                <span>Left</span>
                                <span><%= stats.Left %>%</span>
                            <% } %>
                        </div>

                        <div class="flex flex-col items-center justify-center bg-pol-lean-left border-r border-white/20 transition-all duration-500" 
                            style="width: <%= stats.LeanLeft %>%">
                            <% if (stats.LeanLeft > 5) { %> 
                                <span>Lean Left</span>
                                <span><%= stats.LeanLeft %>%</span>
                            <% } %>
                        </div>

                        <div class="flex flex-col items-center justify-center bg-pol-center border-r border-white/20 transition-all duration-500" 
                            style="width: <%= stats.Center %>%">
                            <% if (stats.Center > 5) { %>
                                <span>Center</span>
                                <span><%= stats.Center %>%</span>
                            <% } %>
                        </div>

                        <div class="flex flex-col items-center justify-center bg-pol-lean-right transition-all duration-500" 
                            style="width: <%= stats.LeanRight %>%">
                            <% if (stats.LeanRight > 5) { %>
                                <span>Lean Right</span>
                                <span><%= stats.LeanRight %>%</span>
                            <% } %>
                        </div>

                        <div class="flex flex-col items-center justify-center bg-pol-right transition-all duration-500" 
                            style="width: <%= stats.Right %>%">
                            <% if (stats.Right > 5) { %>
                                <span>Right</span>
                                <span><%= stats.Right %>%</span>
                            <% } %>
                        </div>

                    </div>

                    <div class="border-t border-gray-200 dark:border-gray-700 mt-2 pt-1">
                        <button onclick="getBiasExplanation(this)" 
                                id="ai-btn-<%= article.id %>" 
                                data-id="<%= article.id %>"
                                data-label="<%= article.label %>"
                                data-title="<%= article.title %>"
                                class="w-full py-0.5 text-gray-500 hover:text-indigo-600 dark:text-gray-400 dark:hover:text-gray-100 text-base font-semibold transition-colors flex items-center justify-center gap-1.5 ai-btn">
                            <span>Why this bias?</span>
                            <svg class="w-2.5 h-2.5 fill-current" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg">
                                <path d="M5 6L0 0.999999L10 1L5 6Z"/>
                            </svg>
                        </button>
                    </div>

                    <div id="bias-explanation-<%= article.id %>" class="mt-2 text-sm text-gray-600 dark:text-gray-400 hidden leading-relaxed pt-2">
                    </div>
                </div>

                <div class="bg-card-light dark:bg-card-dark px-6 pt-5 pb-6 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-bold text-text-light dark:text-text-dark flex items-center gap-2">
                            Explore Related Articles
                        </h3>
                    </div>

                    <div class="space-y-6">
                        <div class="relative pl-4 mb-8"> <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-pol-left dark:bg-blue-600 rounded-full opacity-80"></div>
                            <div class="flex flex-col">
                                <div class="space-y-1">
                                    <% if (recommendations.Left && recommendations.Left.length > 0) { %>
                                        <% recommendations.Left.forEach(rec => { %>
                                            <div class="py-2 border-b border-gray-100 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors rounded-md px-1">
                                                <a href="/article/<%= rec.article_id %>" 
                                                    class="block group"
                                                    onclick="openSplitView(event, '/article/<%= rec.article_id %>')">
                                                    <p class="text-sm font-medium text-text-light dark:text-text-dark line-clamp-2 group-hover:text-primary transition-colors leading-tight">
                                                        <%= rec.title %>
                                                    </p>
                                                </a>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-[11px] text-gray-400 py-2 px-1 italic">no articles available</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="relative pl-4 mb-8"> <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-pol-lean-left dark:bg-blue-600 rounded-full opacity-80"></div>
                            <div class="flex flex-col">
                                <div class="space-y-1">
                                    <% if (recommendations.LeanLeft && recommendations.LeanLeft.length > 0) { %>
                                        <% recommendations.LeanLeft.forEach(rec => { %>
                                            <div class="py-2 border-b border-gray-100 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors rounded-md px-1">
                                                <a href="/article/<%= rec.article_id %>" 
                                                    class="block group"
                                                    onclick="openSplitView(event, '/article/<%= rec.article_id %>')">
                                                    <p class="text-sm font-medium text-text-light dark:text-text-dark line-clamp-2 group-hover:text-primary transition-colors leading-tight">
                                                        <%= rec.title %>
                                                    </p>
                                                </a>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-[11px] text-gray-400 py-2 px-1 italic">no articles available</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="relative pl-4 mb-8"> <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-pol-center dark:bg-gray-600 rounded-full opacity-80"></div>
                            <div class="flex flex-col">
                                <div class="space-y-1">
                                    <% if (recommendations.Center && recommendations.Center.length > 0) { %>
                                        <% recommendations.Center.forEach(rec => { %>
                                            <div class="py-2 border-b border-gray-100 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors rounded-md px-1">
                                                <a href="/article/<%= rec.article_id %>" 
                                                    class="block group"
                                                    onclick="openSplitView(event, '/article/<%= rec.article_id %>')">
                                                    <p class="text-sm font-medium text-text-light dark:text-text-dark line-clamp-2 group-hover:text-primary transition-colors leading-tight">
                                                        <%= rec.title %>
                                                    </p>
                                                </a>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-[11px] text-gray-400 py-2 px-1 italic">no articles available</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="relative pl-4 mb-8"> <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-pol-lean-right dark:bg-blue-600 rounded-full opacity-80"></div>
                            <div class="flex flex-col">
                                <div class="space-y-1">
                                    <% if (recommendations.LeanRight && recommendations.LeanRight.length > 0) { %>
                                        <% recommendations.LeanRight.forEach(rec => { %>
                                            <div class="py-2 border-b border-gray-100 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors rounded-md px-1">
                                                <a href="/article/<%= rec.article_id %>" 
                                                    class="block group"
                                                    onclick="openSplitView(event, '/article/<%= rec.article_id %>')">
                                                    <p class="text-sm font-medium text-text-light dark:text-text-dark line-clamp-2 group-hover:text-primary transition-colors leading-tight">
                                                        <%= rec.title %>
                                                    </p>
                                                </a>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-[11px] text-gray-400 py-2 px-1 italic">no articles available</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="relative pl-4 mb-8"> <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-pol-right dark:bg-red-600 rounded-full opacity-80"></div>
                            <div class="flex flex-col">
                                <div class="space-y-1">
                                    <% if (recommendations.Right && recommendations.Right.length > 0) { %>
                                        <% recommendations.Right.forEach(rec => { %>
                                            <div class="py-2 border-b border-gray-100 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors rounded-md px-1">
                                                <a href="/article/<%= rec.article_id %>" 
                                                    class="block group"
                                                    onclick="openSplitView(event, '/article/<%= rec.article_id %>')">
                                                    <p class="text-sm font-medium text-text-light dark:text-text-dark line-clamp-2 group-hover:text-primary transition-colors leading-tight">
                                                        <%= rec.title %>
                                                    </p>
                                                </a>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-[11px] text-gray-400 py-2 px-1 italic">no articles available</p>
                                    <% } %>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>
                

            </aside>
            <% } %>
        </div>
    </div>

    <script src="/utils.js"></script>
</body>
</html>