<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= article.title %> - News</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6366F1",
                        "background-light": "#F9FAFB",
                        "background-dark": "#1F2937",
                        "card-light": "#FFFFFF",
                        "card-dark": "#374151",
                        "text-light": "#111827",
                        "text-dark": "#F3F4F6",
                        "text-secondary-light": "#6B7280",
                        "text-secondary-dark": "#9CA3AF",
                        "border-light": "#E5E7EB",
                        "border-dark": "#4B5563",
                    },
                    fontFamily: { display: ["Noto Sans KR", "sans-serif"] },
                },
            },
        };
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark font-display">
    <div class="container mx-auto p-4 md:p-8">
        <header class="flex items-center space-x-4 mb-8">
            <div class="flex items-center space-x-4 flex-grow">
                <a href="/" class="flex items-center gap-2 bg-primary text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-indigo-600 transition-colors">
                    <span class="material-icons">home</span>
                </a>
                <div class="relative flex-grow">
                    <input class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-card-light dark:bg-card-dark focus:outline-none focus:ring-2 focus:ring-primary" placeholder="Search news..." type="text"/>
                    <button class="absolute right-0 top-0 h-full px-3 flex items-center bg-primary text-white rounded-r-lg">
                        <span class="material-icons">search</span>
                    </button>
                </div>
            </div>
            <a href="/logout" class="ml-4 bg-gray-200 dark:bg-gray-700 text-text-light dark:text-text-dark px-6 py-2 rounded-lg font-semibold shadow-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-300">
                    log out
            </a>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <main class="lg:col-span-2 space-y-6">
                <article class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <div class="prose dark:prose-invert max-w-none">
                        <span class="inline-block bg-gray-200 dark:bg-gray-600 text-text-light dark:text-text-dark text-sm font-medium px-3 py-1 rounded-full mb-4">
                            <%= article.publisher %>
                        </span>
                        <h1 class="text-3xl font-bold mb-4"><%= article.title %></h1>
                        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 text-sm text-text-secondary-light dark:text-text-secondary-dark mb-6">
                            <span><%= article.reporter %></span>
                            <span class="hidden sm:inline">|</span>
                            <span><%= article.created_at.toLocaleDateString() %></span>
                        </div>

                        <img alt="News Image" class="w-full h-auto rounded-lg mb-6 shadow-sm" src="https://ichef.bbci.co.uk/news/1024/cpsprodpb/6f27/live/b0083d80-c770-11f0-a882-55e7f9e7585f.jpg.webp"/>
                        
                        <div class="text-lg leading-relaxed space-y-4">
                            <%- article.article_content %>
                        </div>
                    </div>
                </article>

                <section class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <h2 class="text-xl font-bold mb-4">Comments <span class="text-primary">23</span></h2>
                    <div class="flex gap-4 mb-6">
                        <input class="flex-grow p-3 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark" placeholder="Add a comment..." type="text"/>
                        <button class="bg-primary text-white font-semibold py-3 px-6 rounded-lg shadow-md">Post</button>
                    </div>
                    </section>
            </main>

            <aside class="space-y-8">
                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <h3 class="text-lg font-semibold mb-4">Political Bias</h3>
                    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-8 overflow-hidden flex text-white text-xs font-bold mb-4">
                        <div class="flex items-center justify-center bg-yellow-400" style="width: <%= article.progress_percent %>%">
                            Pro <%= Math.round(article.progress_percent) %>%
                        </div>
                        <div class="flex items-center justify-center bg-teal-400" style="width: <%= article.conservative_percent %>%">
                            Con <%= Math.round(article.conservative_percent) %>%
                        </div>
                    </div>

                    <% if (article.progress_percent > 60) { %>
                        <div class="bg-yellow-400 p-4 rounded-lg text-white text-center font-bold">Progressive leaning</div>
                    <% } else if (article.conservative_percent > 60) { %>
                        <div class="bg-teal-500 p-4 rounded-lg text-white text-center font-bold">Conservative leaning</div>
                    <% } else { %>
                        <div class="bg-gray-400 p-4 rounded-lg text-white text-center font-bold">Moderate / Neutral</div>
                    <% } %>
                </div>

                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <h3 class="text-lg font-bold mb-4">Different Perspectives</h3>
                    <div class="space-y-4">
                        <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors">Trump ally Marjorie Taylor Greene to quit Congress after Epstein files feud</h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">Washington</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-teal-300 flex-shrink-0"></div>
                        </a>
                        <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors">Marjorie Taylor Greene doubles down on Epstein files amid fallout with Trump</h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">BBC</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-teal-300 flex-shrink-0"></div>
                        </a>
                        <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors">When will the Epstein files be released and will they be redacted?</h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">The White House</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-gray-200 dark:bg-gray-500 flex-shrink-0"></div>
                        </a>
                        <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors">Trump signs bill ordering US justice department to release Epstein files</h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">Fox</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-gray-200 dark:bg-gray-500 flex-shrink-0"></div>
                        </a>
                    </div>
                </div>
                
                
                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <h3 class="text-lg font-bold mb-4">More news</h3>
                    <div class="space-y-4">
                    <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                Why Economic Equality Starts with a Living Wage
                            </h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">The Guardian</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-yellow-400 flex-shrink-0 shadow-sm" title="Progressive leaning"></div>
                    </a>

                    <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                Closing the Gun Show Loophole: A Moral Imperative
                            </h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">New York Times</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-yellow-400 flex-shrink-0 shadow-sm" title="Progressive leaning"></div>
                    </a>

                    <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                Understanding the Infrastructure of Renewable Energy
                            </h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">BBC News</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-gray-300 dark:bg-gray-500 flex-shrink-0 shadow-sm" title="Moderate"></div>
                    </a>

                    <a class="flex items-center gap-4 group" href="#">
                        <div class="flex-grow">
                            <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                The Future of Bipartisan Cooperation in the Senate
                            </h4>
                            <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">Reuters</p>
                        </div>
                        <div class="w-6 h-6 rounded-full bg-gray-300 dark:bg-gray-500 flex-shrink-0 shadow-sm" title="Moderate"></div>
                    </a>
                </div>
                </div>
            </aside>
        </div>
    </div>
</body>
</html>