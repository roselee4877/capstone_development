<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= article.title %> - News</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6366F1",
                        "background-light": "#F9FAFB",
                        "background-dark": "#1F2937",
                        "card-light": "#FFFFFF",
                        "card-dark": "#374151",
                        "text-light": "#111827",
                        "text-dark": "#F3F4F6",
                        "text-secondary-light": "#6B7280",
                        "text-secondary-dark": "#9CA3AF",
                        "border-light": "#E5E7EB",
                        "border-dark": "#4B5563",
                    },
                    fontFamily: { display: ["Noto Sans KR", "sans-serif"] },
                },
            },
        };
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark font-display">
    <div class="container mx-auto px-4 md:px-12 lg:px-20 py-8 max-w-7xl">
        <header class="flex items-center space-x-4 mb-8">
            <div class="flex items-center space-x-4 flex-grow">
                <a href="/" class="flex items-center gap-2 bg-primary text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-indigo-600 transition-colors">
                    <span class="material-icons">home</span>
                </a>
                <div class="relative flex-grow">
                    <input id="searchInput" 
                        class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-card-light dark:bg-card-dark focus:outline-none focus:ring-2 focus:ring-primary" 
                        placeholder="Search by keyword" 
                        type="text"
                        onkeyup="if(window.event.keyCode==13){executeSearch()}"/>
                        
                    <button onclick="executeSearch()" 
                            class="absolute right-0 top-0 h-full px-3 flex items-center bg-primary text-white rounded-r-lg hover:bg-indigo-700 transition-colors duration-300">
                        <span class="material-icons">search</span>
                    </button>
                </div>
            </div>
            <a href="/logout" class="ml-4 bg-gray-200 dark:bg-gray-700 text-text-light dark:text-text-dark px-6 py-2 rounded-lg font-semibold shadow-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-300">
                    log out
            </a>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <main class="lg:col-span-2 space-y-6">
                <article class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <div class="prose dark:prose-invert max-w-none">
                        <% if (article.publisher) { %>
                            <span class="inline-block bg-gray-200 dark:bg-gray-600 text-text-light dark:text-text-dark text-sm font-medium px-3 py-1 rounded-full mb-4">
                                <%= article.publisher %>
                            </span>
                        <% } %>

                        <h1 class="text-3xl font-bold mb-4"><%= article.title %></h1>

                        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 text-sm text-text-secondary-light dark:text-text-secondary-dark mb-6">
                            <% if (article.reporter) { %>
                                <span><%= article.reporter %></span>
                            <% } %>
                            
                            <% if (article.reporter && article.created_at) { %>
                                <span class="hidden sm:inline">|</span>
                            <% } %>

                            <% if (article.created_at) { %>
                                <span><%= (article.created_at instanceof Date) ? article.created_at.toLocaleDateString() : article.created_at %></span>
                            <% } %>
                        </div>
                        
                        <div class="text-lg leading-relaxed space-y-4">
                            <% 
                                // 1. 서버에서 전달받은 keywords 배열 사용 (없을 경우를 대비해 빈 배열 기본값)
                                const currentKeywords = (typeof keywords !== 'undefined' && keywords) ? keywords : [];

                                // 2. 본문 내용 가져오기 (null 방지)
                                let highlightedContent = article.article_content || '';

                                // 3. article.label에 따른 색상 클래스 결정
                                let colorClass = "";
                                const label = article.label; // Left, Center, Right 중 하나

                                if (label === 'Left') {
                                    // 진보(Left): Yellow 계열
                                    colorClass = "bg-yellow-200 dark:bg-yellow-900/50 border-yellow-400";
                                } else if (label === 'Right') {
                                    // 보수(Right): Teal 계열
                                    colorClass = "bg-teal-200 dark:bg-teal-900/50 border-teal-400";
                                } else {
                                    // 중도(Center) 또는 기타: Gray 계열
                                    colorClass = "bg-gray-200 dark:bg-gray-700/50 border-gray-400";
                                }

                                // 4. 하이라이트 로직 실행
                                if (highlightedContent && currentKeywords.length > 0) {
                                    // 키워드가 긴 것부터 정렬 (짧은 단어가 긴 단어의 일부를 먼저 하이라이트하는 것 방지)
                                    const sortedKeywords = [...currentKeywords].sort((a, b) => b.length - a.length);

                                    sortedKeywords.forEach(word => {
                                        if (word && word.trim() !== '') {
                                            // 정규식 특수문자 이스케이프 처리
                                            const escapedWord = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                                            const regex = new RegExp(`(${escapedWord})`, 'gi');
                                            
                                            // 위에서 결정된 colorClass를 사용하여 replace 실행
                                            highlightedContent = highlightedContent.replace(
                                                regex, 
                                                `<span class="${colorClass} border-b-2 font-medium cursor-pointer keyword-highlight" 
                                                    onclick="explainKeyword('${escapedWord}', '${label}')">$1</span>`
                                            );
                                        }
                                    });
                                }
                            %>

                            <div class="text-lg leading-relaxed space-y-4 article-body">
                                <%- highlightedContent %>
                            </div>
                        </div>
                    </div>
                </article>

                
            </main>

            <div id="keywordModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden items-center justify-center z-50 p-4 transition-all duration-300" onclick="if(event.target === this) closeModal()">
                <div class="bg-card-light dark:bg-card-dark max-w-2xl w-full rounded-2xl shadow-2xl flex flex-col max-h-[75vh] overflow-hidden transform transition-all shadow-indigo-500/10">
                    
                    <div class="px-6 py-4 border-b border-border-light dark:border-border-dark flex items-center justify-between bg-gray-50/50 dark:bg-gray-800/50">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                                <span class="material-icons text-primary">auto_awesome</span>
                            </div>
                            <div>
                                <h3 id="modalTitle" class="text-xl font-bold text-text-light dark:text-text-dark tracking-tight"></h3>
                                <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark font-medium  tracking-wider">Why is this keyword highlighted?</p>
                            </div>
                        </div>
                        <button onclick="closeModal()" class="p-2 rounded-xl hover:bg-gray-200 dark:hover:bg-gray-700 transition-all group">
                            <span class="material-icons text-text-secondary-light group-hover:rotate-90 transition-transform duration-300">close</span>
                        </button>
                    </div>

                    <div id="modalContent" class="p-8 overflow-y-auto text-text-light dark:text-text-dark leading-relaxed text-lg whitespace-pre-wrap scrollbar-thin scrollbar-thumb-gray-300 dark:scrollbar-thumb-gray-600">
                        </div>
                </div>
            </div>

            <script>
                async function explainKeyword(keyword, label) {
                    const modal = document.getElementById('keywordModal');
                    const title = document.getElementById('modalTitle');
                    const content = document.getElementById('modalContent');

                    // 모달 열기 및 로딩 표시
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    title.innerText = `${keyword}`;
                    content.innerHTML = '<div class="flex justify-center"><span class="animate-spin material-icons">sync</span> Analyzing...</div>';

                    // 1. 기사 본문 텍스트 추출 (하이라이트 태그 등을 제외한 순수 텍스트만 가져옴)
                    const articleElement = document.querySelector('.article-body');
                    const articleText = articleElement ? articleElement.innerText : "";

                    try {
                        const response = await fetch('/api/explain-keyword', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            // 2. body에 content(본문) 추가
                            body: JSON.stringify({ 
                                keyword: keyword, 
                                label: label, 
                                title: "<%= article.title %>",
                                content: articleText // 추출한 본문 텍스트 전달
                            })
                        });
                        const data = await response.json();
                        content.innerText = data.explanation;
                    } catch (error) {
                        console.error("Error:", error);
                        content.innerText = "Explanation could not be retrieved.";
                    }
                }

                function closeModal() {
                    document.getElementById('keywordModal').classList.add('hidden');
                    document.getElementById('keywordModal').classList.remove('flex');
                }
            </script>

            <aside class="space-y-8">
                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md">
                    <h3 class="text-lg font-semibold mb-4">Political Bias</h3>
                    <div class="flex space-x-2 text-sm">
                        <% if (article.label === 'Right') { %>
                            <span class="bg-teal-200 text-teal-800 dark:bg-teal-900 dark:text-teal-300 px-2 py-1 rounded-full font-medium">Con</span>
                        <% } else if (article.label === 'Left') { %>
                            <span class="bg-yellow-200 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300 px-2 py-1 rounded-full font-medium">Pro</span>
                        <% } else { %>
                            <span class="bg-gray-200 text-gray-800 dark:bg-gray-900 dark:text-gray-300 px-2 py-1 rounded-full font-medium">Mod</span>
                        <% } %>
                    </div>

        
                </div>

                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md border-t-4 border-yellow-500">
                    <div class="mb-4">
                        <h3 class="text-lg font-bold text-yellow-500">Progressive View</h3>
                    </div>

                    <div class="space-y-4">
                        <% if (recommendations.Left && recommendations.Left.length > 0) { %>
                            <% recommendations.Left.forEach(rec => { %>
                                <a class="flex items-center gap-4 group" href="/article/<%= rec.article_id %>">
                                    <div class="flex-grow">
                                        <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                            <%= rec.title %>
                                        </h4>
                                    </div>
                                </a>
                            <% }) %>
                        <% } else { %>
                            <p class="text-sm text-gray-400">empty</p>
                        <% } %>
                    </div>
                </div>
                
                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md border-t-4 border-gray-500">
                    <div class="mb-4">
                        <h3 class="text-lg font-bold text-gray-500">Center View</h3>
                    </div>

                    <div class="space-y-4">
                        <% if (recommendations.Center && recommendations.Center.length > 0) { %>
                            <% recommendations.Center.forEach(rec => { %>
                                <a class="flex items-center gap-4 group" href="/article/<%= rec.article_id %>">
                                    <div class="flex-grow">
                                        <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                            <%= rec.title %>
                                        </h4>
                                    </div>
                                </a>
                            <% }) %>
                        <% } else { %>
                            <p class="text-sm text-gray-400">empty</p>
                        <% } %>
                    </div>
                </div>

                <div class="bg-card-light dark:bg-card-dark p-6 rounded-lg shadow-md border-t-4 border-teal-500">
                    <div class="mb-4">
                        <h3 class="text-lg font-bold text-teal-500">Conservative View</h3>
                    </div>

                    <div class="space-y-4">
                        <% if (recommendations.Right && recommendations.Right.length > 0) { %>
                            <% recommendations.Right.forEach(rec => { %>
                                <a class="flex items-center gap-4 group" href="/article/<%= rec.article_id %>">
                                    <div class="flex-grow">
                                        <h4 class="font-semibold group-hover:text-primary transition-colors line-clamp-2">
                                            <%= rec.title %>
                                        </h4>
                                    </div>
                                </a>
                            <% }) %>
                        <% } else { %>
                            <p class="text-sm text-gray-400">empty</p>
                        <% } %>
                    </div>
                </div>
                
                

            </aside>
        </div>
    </div>

    <script>
        console.log("script loaded\n");
        function executeSearch() {
            console.log("search\n");
            const query = document.getElementById('searchInput').value;
            if (!query) {
                alert("Please enter a search term.");
                return;
            }

            // 검색 페이지로 이동
            location.href = `/search?q=${encodeURIComponent(query)}`;
        }
    </script>
</body>
</html>