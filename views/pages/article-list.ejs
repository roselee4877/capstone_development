<!DOCTYPE html>
<html lang="ko"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>News Prism</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
<script>
    const colors = tailwind.colors;
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6366F1",
                        "background-light": "#F3F4F6",
                        "background-dark": "#1F2937",
                        "card-light": "#FFFFFF",
                        "card-dark": "#374151",
                        "text-light": "#111827",
                        "text-dark": "#F9FAFB",
                        "subtext-light": "#6B7280",
                        "subtext-dark": "#9CA3AF",
                        
                        "pol-left": colors.blue[400],
                        "pol-lean-left": colors.blue[200],
                        "pol-center": colors.gray[300],
                        "pol-lean-right": colors.red[200],
                        "pol-right": colors.red[400],
                    },
                    fontFamily: {
                        display: ["Noto Sans KR", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                    },
                },
            },
        };
</script>
<style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
        }
</style>

<header style="
    display: flex; 
    justify-content: center; 
    padding-top: 2.5rem;    /* 위쪽 여백은 원래의 넉넉한 느낌 유지 */
    padding-bottom: 0.5rem; /* 아래쪽 여백은 대폭 줄임 */
    background: none;
    text-shadow: 2px 2px 4px rgba(79, 70, 229, 0.1);
">
    <h1 style="
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
        font-size: 3rem; 
        font-weight: 900; 
        color: #4f46e5;      /* 인디고 색상 */
        margin: 0;
        line-height: 1; 
        letter-spacing: -0.06em;
        text-transform: uppercase;
    ">
        Prism
    </h1>
</header>
</head>
    <body class="bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark font-display">
        <div class="container mx-auto px-6 lg:px-20 py-8 max-w-7xl">
            <header class="flex items-center space-x-4 mb-8">
                <div class="flex items-center space-x-4 flex-grow">
                    <!--홈버튼-->
                    <a href="/">
                        <button class="flex items-center gap-2 bg-primary text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-indigo-600 transition-colors">
                            <span class="material-icons">home</span>
                        </button>
                    </a>
                    <!--검색어창-->
                    <div class="relative flex-grow">
                        <input id="searchInput" 
                            class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-card-light dark:bg-card-dark focus:outline-none focus:ring-2 focus:ring-primary" 
                            placeholder="Search by keyword" 
                            type="text"
                            onkeyup="if(window.event.keyCode==13){executeSearch()}"/>
                            
                        <button onclick="executeSearch()" 
                                class="absolute right-0 top-0 h-full px-3 flex items-center bg-primary text-white rounded-r-lg hover:bg-indigo-700 transition-colors duration-300">
                            <span class="material-icons">search</span>
                        </button>
                    </div>
                </div>
                <!--my버튼-->
                <a href="/logout" class="ml-4 bg-gray-200 dark:bg-gray-700 text-text-light dark:text-text-dark px-6 py-2 rounded-lg font-semibold shadow-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-300">
                    log out
                </a>
            </header>
<main class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
        <div class="bg-card-light dark:bg-card-dark rounded-xl shadow-lg overflow-hidden">
            
            <% if (articles && articles.length > 0) { %>
                <% articles.forEach((article, index) => { %>
                    <div class="p-6 border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors duration-200 last:border-b-0">
                        <div class="flex space-x-6">
                            <div class="flex-grow">
                                <div class="flex flex-col">
                                    <div class="flex items-center gap-3">
                                        <div class="flex space-x-2 text-sm shrink-0">
                                            <% if (article.label === 'Right') { %>
                                                <span class="bg-pol-right text-white dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded-full font-medium">RGT</span>
                                            <% } else if (article.label === 'Lean Right') { %>
                                                <span class="bg-pol-lean-right text-white dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded-full font-medium">L-R</span>
                                            <% }else if (article.label === 'Lean Left') { %>
                                                <span class="bg-pol-lean-left text-white dark:bg-blue-900 dark:text-blue-300 px-2 py-1 rounded-full font-medium">L-L</span>
                                            <% } else if (article.label === 'Left') { %>
                                                <span class="bg-pol-left text-white dark:bg-blue-900 dark:text-blue-300 px-2 py-1 rounded-full font-medium">LFT</span>                            
                                            <% } else { %>
                                                <span class="bg-pol-center text-white dark:bg-gray-900 dark:text-gray-300 px-2 py-1 rounded-full font-medium">CEN</span>
                                            <% } %>
                                        </div>
                                        
                                        <h2 class="text-lg font-bold text-text-light dark:text-text-dark">
                                            <a href="/article/<%= article.article_id %>" 
                                            onclick="logClick('<%= article.article_id %>'); return true;"
                                            class="hover:text-indigo-600 transition-colors">
                                                <%= article.title %>
                                            </a>
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="p-10 text-center">
                    <p class="text-subtext-light dark:text-subtext-dark">no news</p>
                </div>
            <% } %>
        </div>
    </div>



    <aside class="space-y-8">
        <div class="bg-card-light dark:bg-card-dark px-6 pt-3 pb-6 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
            <h3 class="text-lg font-bold mb-3 text-text-light dark:text-text-dark">My Weekly Bias Stats</h3>
            
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-xl h-14 overflow-hidden flex text-white text-xs font-bold shadow-inner">
                
                <div class="flex flex-col items-center justify-center bg-pol-left border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.weekly.Left %>%">
                    <% if (stats.weekly.Left > 5) { %> 
                        <span>Left</span>
                        <span><%= stats.weekly.Left %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-lean-left border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.weekly.LeanLeft %>%">
                    <% if (stats.weekly.LeanLeft > 5) { %> 
                        <span>Lean Left</span>
                        <span><%= stats.weekly.LeanLeft %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-center border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.weekly.Center %>%">
                    <% if (stats.weekly.Center > 5) { %>
                        <span>Center</span>
                        <span><%= stats.weekly.Center %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-lean-right transition-all duration-500" 
                    style="width: <%= stats.weekly.LeanRight %>%">
                    <% if (stats.weekly.LeanRight > 5) { %>
                        <span>Lean Right</span>
                        <span><%= stats.weekly.LeanRight %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-right transition-all duration-500" 
                    style="width: <%= stats.weekly.Right %>%">
                    <% if (stats.weekly.Right > 5) { %>
                        <span>Right</span>
                        <span><%= stats.weekly.Right %>%</span>
                    <% } %>
                </div>

            </div>

            <% if (stats.weekly.Left === 0 && stats.weekly.LeanLeft === 0 && 
            stats.weekly.Center === 0 && stats.weekly.LeanRight === 0 && stats.weekly.Right === 0) { %>
                <p class="text-[10px] text-center mt-2 text-subtext-light">no recent activity</p>
            <% } %>
        
            <div class="border-t border-gray-100 dark:border-gray-700 mb-6"></div>

            <h3 class="text-lg font-bold mb-3 text-text-light dark:text-text-dark">My Overall Bias Stats</h3>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-xl h-14 overflow-hidden flex text-white text-xs font-bold shadow-inner">
                
                <div class="flex flex-col items-center justify-center bg-pol-left border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.total.Left %>%">
                    <% if (stats.total.Left > 5) { %> 
                        <span>Left</span>
                        <span><%= stats.total.Left %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-lean-left border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.total.LeanLeft %>%">
                    <% if (stats.total.LeanLeft > 5) { %> 
                        <span>Lean Left</span>
                        <span><%= stats.total.LeanLeft %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-center border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.total.Center %>%">
                    <% if (stats.total.Center > 5) { %>
                        <span>Center</span>
                        <span><%= stats.total.Center %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-lean-right transition-all duration-500" 
                    style="width: <%= stats.total.LeanRight %>%">
                    <% if (stats.total.LeanRight > 5) { %>
                        <span>Lean Right</span>
                        <span><%= stats.total.LeanRight %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-right transition-all duration-500" 
                    style="width: <%= stats.total.Right %>%">
                    <% if (stats.total.Right > 5) { %>
                        <span>Right</span>
                        <span><%= stats.total.Right %>%</span>
                    <% } %>
                </div>

            </div>

            <% if (stats.total.Left === 0 && stats.total.LeanLeft === 0 && 
            stats.total.Center === 0 && stats.total.LeanRight === 0 && stats.total.Right === 0) { %>
                <p class="text-[10px] text-center mt-2 text-subtext-light">no recent activity</p>
            <% } %>
        </div>

        <div class="bg-card-light dark:bg-card-dark px-6 pt-3 pb-6 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
            <h3 class="text-lg font-bold mb-3 text-text-light dark:text-text-dark">Political Bias in My Feed</h3>
            
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-xl h-14 overflow-hidden flex text-white text-xs font-bold shadow-inner">
                
                <div class="flex flex-col items-center justify-center bg-pol-left border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.recommend.Left %>%">
                    <% if (stats.recommend.Left > 5) { %> 
                        <span>Left</span>
                        <span><%= stats.recommend.Left %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-lean-left border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.recommend.LeanLeft %>%">
                    <% if (stats.recommend.LeanLeft > 5) { %> 
                        <span>Lean Left</span>
                        <span><%= stats.recommend.LeanLeft %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-center border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.recommend.Center %>%">
                    <% if (stats.recommend.Center > 5) { %>
                        <span>Center</span>
                        <span><%= stats.recommend.Center %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-lean-right transition-all duration-500" 
                    style="width: <%= stats.recommend.LeanRight %>%">
                    <% if (stats.recommend.LeanRight > 5) { %>
                        <span>Lean Right</span>
                        <span><%= stats.recommend.LeanRight %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-pol-right transition-all duration-500" 
                    style="width: <%= stats.recommend.Right %>%">
                    <% if (stats.recommend.Right > 5) { %>
                        <span>Right</span>
                        <span><%= stats.recommend.Right %>%</span>
                    <% } %>
                </div>

            </div>

            <% if (stats.recommend.Left === 0 && stats.recommend.LeanLeft === 0 && 
            stats.recommend.Center === 0 && stats.recommend.LeanRight === 0 && stats.recommend.Right === 0) { %>
                <p class="text-[10px] text-center mt-2 text-subtext-light">no data</p>
            <% } %>
        </div>

        
    </aside>
</main>

<div class="w-full flex justify-center items-center space-x-4 mt-12 mb-10">
    
    <% if (currentPage > 1) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=1" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="First Page">
            <span class="material-icons text-2xl">first_page</span>
        </a>
    <% } %>

    <% if (currentPage > 1) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= currentPage - 1 %>" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="Previous Page">
            <span class="material-icons text-2xl">chevron_left</span>
        </a>
    <% } %>

    <div class="flex items-center space-x-4 mx-2">
        <% for(let i = startPage; i <= endPage; i++) { %>
            <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= i %>" 
               class="text-lg transition-all duration-200 
               <%= currentPage === i 
                   ? 'text-primary font-bold border-b-2 border-primary pb-1' 
                   : 'text-subtext-light dark:text-subtext-dark hover:text-text-light dark:hover:text-text-dark font-medium' %>">
                <%= i %>
            </a>
        <% } %>
    </div>

    <% if (currentPage < totalPages) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= currentPage + 1 %>" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="Next Page">
            <span class="material-icons text-2xl">chevron_right</span>
        </a>
    <% } %>

    <% if (currentPage < totalPages) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= totalPages %>" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="Last Page">
            <span class="material-icons text-2xl">last_page</span>
        </a>
    <% } %>

</div>

</div>

<script src="/utils.js"></script>

</body>
</html>