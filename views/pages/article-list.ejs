<!DOCTYPE html>
<html lang="ko"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>뉴스 추천 사이트</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
<script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6366F1",
                        "background-light": "#F3F4F6",
                        "background-dark": "#1F2937",
                        "card-light": "#FFFFFF",
                        "card-dark": "#374151",
                        "text-light": "#111827",
                        "text-dark": "#F9FAFB",
                        "subtext-light": "#6B7280",
                        "subtext-dark": "#9CA3AF"
                    },
                    fontFamily: {
                        display: ["Noto Sans KR", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                    },
                },
            },
        };
    </script>
<style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
        }
    </style>
</head>
    <body class="bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark font-display">
        <div class="container mx-auto px-4 py-8">
            <header class="flex items-center space-x-4 mb-8">
                <div class="flex items-center space-x-4 flex-grow">
                    <!--홈버튼-->
                    <button class="flex items-center gap-2 bg-primary text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-indigo-600 transition-colors">
                        <span class="material-icons">home</span>
                    </button>
                    <!--검색어창-->
                    <div class="relative flex-grow">
                        <input class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-card-light dark:bg-card-dark focus:outline-none focus:ring-2 focus:ring-primary" placeholder="검색어 입력" type="text"/>
                        <button class="absolute right-0 top-0 h-full px-3 flex items-center bg-primary text-white rounded-r-lg hover:bg-indigo-700 transition-colors duration-300">
                            <span class="material-icons">search</span>
                        </button>
                    </div>
                </div>
                <!--my버튼-->
                <a href="/logout" class="ml-4 bg-gray-200 dark:bg-gray-700 text-text-light dark:text-text-dark px-6 py-2 rounded-lg font-semibold shadow-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-300">
                    log out
                </a>
            </header>
<main class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-6">
        <% if (articles && articles.length > 0) { %>
            <% articles.forEach(article => { %>
                <div class="bg-card-light dark:bg-card-dark p-6 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300 flex space-x-6">
                    <div class="flex-grow">
                        <div class="flex justify-between items-start mb-2">
                            <h2 class="text-xl font-bold text-text-light dark:text-text-dark">
                                <a href="/article/<%= article.article_id %>">
                                    <%= article.title %>
                                </a>
                            </h2>
                            <div class="flex space-x-2 text-sm">
                                <% if (article.conservative_percent > 60) { %>
                                    <span class="bg-teal-200 text-teal-800 dark:bg-teal-900 dark:text-teal-300 px-2 py-1 rounded-full font-medium">Con</span>
                                <% } else if (article.progress_percent > 60) { %>
                                    <span class="bg-yellow-200 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300 px-2 py-1 rounded-full font-medium">Pro</span>
                                <% } else { %>
                                    <span class="bg-gray-200 text-gray-800 dark:bg-gray-900 dark:text-gray-300 px-2 py-1 rounded-full font-medium">Mod</span>
                                <% } %>
                            </div>
                        </div>
                        <p class="text-subtext-light dark:text-subtext-dark mb-4">
                            <%= article.summary %>
                        </p>
                        <div class="flex space-x-2 text-sm text-subtext-light dark:text-subtext-dark">
                            <span class="bg-gray-200 dark:bg-gray-700 px-3 py-1 rounded-full"><%= article.publisher %></span>
                            <span class="bg-gray-200 dark:bg-gray-700 px-3 py-1 rounded-full"><%= article.created_at.toLocaleDateString() %></span>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <p class="text-center py-10">no news</p>
        <% } %>
    </div>



    <aside class="space-y-8">
        <div class="bg-card-light dark:bg-card-dark p-6 rounded-xl shadow-lg">
            <h3 class="text-lg font-bold mb-4 text-text-light dark:text-text-dark">My Weekly Political Lean</h3>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-6 overflow-hidden flex text-white text-xs font-medium">
                <div class="flex items-center justify-center bg-yellow-400" style="width: 20%">pro 20%</div>
                <div class="flex items-center justify-center bg-gray-300" style="width: 40%">mod 40%</div>
                <div class="flex items-center justify-center bg-teal-400" style="width: 40%">con 40%</div>
            </div>
        </div>
        <div class="bg-card-light dark:bg-card-dark p-6 rounded-xl shadow-lg">
            <h3 class="text-lg font-bold mb-4 text-text-light dark:text-text-dark">My Overall Political Lean</h3>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-6 overflow-hidden flex text-white text-xs font-medium">
            <div class="flex items-center justify-center bg-yellow-400" style="width: 40%">pro 40%</div>
            <div class="flex items-center justify-center bg-gray-300" style="width: 30%">mod 30%</div>
            <div class="flex items-center justify-center bg-teal-400" style="width: 30%">con 30%</div>
            </div>
        </div>
    </aside>
</main>
</div>

</body>
</html>