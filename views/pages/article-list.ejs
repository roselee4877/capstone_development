<!DOCTYPE html>
<html lang="ko"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>뉴스 추천 사이트</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
<script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#6366F1",
                        "background-light": "#F3F4F6",
                        "background-dark": "#1F2937",
                        "card-light": "#FFFFFF",
                        "card-dark": "#374151",
                        "text-light": "#111827",
                        "text-dark": "#F9FAFB",
                        "subtext-light": "#6B7280",
                        "subtext-dark": "#9CA3AF"
                    },
                    fontFamily: {
                        display: ["Noto Sans KR", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                    },
                },
            },
        };
</script>
<style>
        body {
            font-family: 'Noto Sans KR', sans-serif;
        }
</style>
</head>
    <body class="bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark font-display">
        <div class="container mx-auto px-6 lg:px-20 py-8 max-w-7xl">
            <header class="flex items-center space-x-4 mb-8">
                <div class="flex items-center space-x-4 flex-grow">
                    <!--홈버튼-->
                    <a href="/">
                        <button class="flex items-center gap-2 bg-primary text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-indigo-600 transition-colors">
                            <span class="material-icons">home</span>
                        </button>
                    </a>
                    <!--검색어창-->
                    <div class="relative flex-grow">
                        <input id="searchInput" 
                            class="w-full pl-4 pr-10 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-card-light dark:bg-card-dark focus:outline-none focus:ring-2 focus:ring-primary" 
                            placeholder="Search by keyword" 
                            type="text"
                            onkeyup="if(window.event.keyCode==13){executeSearch()}"/>
                            
                        <button onclick="executeSearch()" 
                                class="absolute right-0 top-0 h-full px-3 flex items-center bg-primary text-white rounded-r-lg hover:bg-indigo-700 transition-colors duration-300">
                            <span class="material-icons">search</span>
                        </button>
                    </div>
                </div>
                <!--my버튼-->
                <a href="/logout" class="ml-4 bg-gray-200 dark:bg-gray-700 text-text-light dark:text-text-dark px-6 py-2 rounded-lg font-semibold shadow-md hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors duration-300">
                    log out
                </a>
            </header>
<main class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
        <div class="bg-card-light dark:bg-card-dark rounded-xl shadow-lg overflow-hidden">
            
            <% if (articles && articles.length > 0) { %>
                <% articles.forEach((article, index) => { %>
                    <div class="p-6 border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors duration-200 last:border-b-0">
                        <div class="flex space-x-6">
                            <div class="flex-grow">
                                <div class="flex flex-col mb-2">
                                    <div class="flex items-center gap-3">
                                        <div class="flex space-x-2 text-sm shrink-0">
                                            <% if (article.label === 'Right') { %>
                                                <span class="bg-red-200 text-red-800 dark:bg-red-900 dark:text-red-300 px-2 py-1 rounded-full font-medium">Con</span>
                                            <% } else if (article.label === 'Left') { %>
                                                <span class="bg-blue-200 text-blue-800 dark:bg-blue-900 dark:text-blue-300 px-2 py-1 rounded-full font-medium">Pro</span>
                                            <% } else { %>
                                                <span class="bg-gray-200 text-gray-800 dark:bg-gray-900 dark:text-gray-300 px-2 py-1 rounded-full font-medium">Mod</span>
                                            <% } %>
                                        </div>
                                        
                                        <h2 class="text-lg font-bold text-text-light dark:text-text-dark">
                                            <a href="/article/<%= article.article_id %>" 
                                            onclick="logClick('<%= article.article_id %>'); return true;"
                                            class="hover:text-indigo-600 transition-colors">
                                                <%= article.title %>
                                            </a>
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="p-10 text-center">
                    <p class="text-subtext-light dark:text-subtext-dark">no news</p>
                </div>
            <% } %>
        </div>
    </div>



    <aside class="space-y-8">
        <div class="bg-card-light dark:bg-card-dark px-6 pt-3 pb-6 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
            <h3 class="text-lg font-bold mb-3 text-text-light dark:text-text-dark">My Weekly Political Lean</h3>
            
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-xl h-14 overflow-hidden flex text-white text-xs font-bold shadow-inner">
                
                <div class="flex flex-col items-center justify-center bg-blue-300 border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.weekly.progressive %>%">
                    <% if (stats.weekly.progressive > 5) { %> 
                        <span>pro</span>
                        <span><%= stats.weekly.progressive %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-gray-300 border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.weekly.moderate %>%">
                    <% if (stats.weekly.moderate > 5) { %>
                        <span>mod</span>
                        <span><%= stats.weekly.moderate %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-red-300 transition-all duration-500" 
                    style="width: <%= stats.weekly.conservative %>%">
                    <% if (stats.weekly.conservative > 5) { %>
                        <span>con</span>
                        <span><%= stats.weekly.conservative %>%</span>
                    <% } %>
                </div>

            </div>

            <% if (stats.weekly.progressive === 0 && stats.weekly.moderate === 0 && stats.weekly.conservative === 0) { %>
                <p class="text-[10px] text-center mt-2 text-subtext-light">기록된 활동 데이터가 없습니다.</p>
            <% } %>
        
            <div class="border-t border-gray-100 dark:border-gray-700 mb-6"></div>

            <h3 class="text-lg font-bold mb-3 text-text-light dark:text-text-dark">My Overall Political Lean</h3>
            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-xl h-14 overflow-hidden flex text-white text-xs font-bold shadow-inner">
                
                <div class="flex flex-col items-center justify-center bg-blue-300 border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.total.progressive %>%">
                    <% if (stats.total.progressive > 5) { %> 
                        <span>pro</span>
                        <span><%= stats.total.progressive %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-gray-300 border-r border-white/20 transition-all duration-500" 
                    style="width: <%= stats.total.moderate %>%">
                    <% if (stats.total.moderate > 5) { %>
                        <span>mod</span>
                        <span><%= stats.total.moderate %>%</span>
                    <% } %>
                </div>

                <div class="flex flex-col items-center justify-center bg-red-300 transition-all duration-500" 
                    style="width: <%= stats.total.conservative %>%">
                    <% if (stats.total.conservative > 5) { %>
                        <span>con</span>
                        <span><%= stats.total.conservative %>%</span>
                    <% } %>
                </div>

            </div>

            <% if (stats.total.progressive === 0 && stats.total.moderate === 0 && stats.total.conservative === 0) { %>
                <p class="text-[10px] text-center mt-2 text-subtext-light">기록된 활동 데이터가 없습니다.</p>
            <% } %>
        </div>

        <div class="bg-card-light dark:bg-card-dark px-6 pt-3 pb-6 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold mb-2 text-text-light dark:text-text-dark">Recent History</h3>
            </div>

            <div class="space-y-0">
                <% if (recentLogs && recentLogs.length > 0) { %>
                    <% recentLogs.forEach(log => { %>
                        <div class="py-3 border-b border-gray-100 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors rounded-md px-1">
                            <a href="/article/<%= log.article_id %>" class="block group">
                                <div class="flex items-center gap-3"> 
                                    
                                    <div class="shrink-0">
                                        <% if (log.label === 'Right') { %>
                                            <span class="block w-3 h-3 bg-red-300 dark:bg-red-400 rounded-full shadow-sm"></span>
                                        <% } else if (log.label === 'Left') { %>
                                            <span class="block w-3 h-3 bg-blue-300 dark:bg-blue-400 rounded-full shadow-sm"></span>
                                        <% } else { %>
                                            <span class="block w-3 h-3 bg-gray-300 dark:bg-gray-500 rounded-full shadow-sm"></span>
                                        <% } %>
                                    </div>

                                    <div class="flex-grow min-w-0"> <p class="text-sm font-medium text-text-light dark:text-text-dark line-clamp-2 group-hover:text-primary transition-colors mb-0.5 leading-tight">
                                            <%= log.title %>
                                        </p>
                                        <div class="flex items-center text-[10px] text-subtext-light dark:text-subtext-dark opacity-80">
                                            <span><%= log.publisher %></span>
                                        </div>
                                    </div>

                                </div>
                            </a>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-center py-6 text-xs text-subtext-light">No recent activity</p>
                <% } %>
            </div>
        </div>
    </aside>
</main>

<div class="w-full flex justify-center items-center space-x-4 mt-12 mb-10">
    
    <% if (currentPage > 1) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=1" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="First Page">
            <span class="material-icons text-2xl">first_page</span>
        </a>
    <% } %>

    <% if (currentPage > 1) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= currentPage - 1 %>" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="Previous Page">
            <span class="material-icons text-2xl">chevron_left</span>
        </a>
    <% } %>

    <div class="flex items-center space-x-4 mx-2">
        <% for(let i = startPage; i <= endPage; i++) { %>
            <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= i %>" 
               class="text-lg transition-all duration-200 
               <%= currentPage === i 
                   ? 'text-primary font-bold border-b-2 border-primary pb-1' 
                   : 'text-subtext-light dark:text-subtext-dark hover:text-text-light dark:hover:text-text-dark font-medium' %>">
                <%= i %>
            </a>
        <% } %>
    </div>

    <% if (currentPage < totalPages) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= currentPage + 1 %>" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="Next Page">
            <span class="material-icons text-2xl">chevron_right</span>
        </a>
    <% } %>

    <% if (currentPage < totalPages) { %>
        <a href="?q=<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>&page=<%= totalPages %>" 
           class="text-subtext-light dark:text-subtext-dark hover:text-primary transition-colors duration-200"
           title="Last Page">
            <span class="material-icons text-2xl">last_page</span>
        </a>
    <% } %>

</div>

</div>

<script src="/utils.js"></script>

</body>
</html>